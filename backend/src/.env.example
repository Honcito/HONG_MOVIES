# --- CONFIGURACIÓN DEL SERVIDOR ---
PORT=3000
FRONTEND_URL=https://tu-app.netlify.app

# --- BASE DE DATOS (MongoDB Atlas) ---
# Reemplazar con tu propia cadena de conexión
MONGO_URI=mongodb+srv://USUARIO:PASSWORD@cluster.mongodb.net/nombre_db?retryWrites=true&w=majority

# --- SEGURIDAD (JWT) ---
# Generar una cadena aleatoria y segura para firmar los tokens
JWT_SECRET=TU_JWT_SECRET_SUPER_SEGURO

# --- RUTAS DE ALMACENAMIENTO (Multimedia) ---
# Ruta absoluta en el servidor físico donde se alojan los videos
LOCAL_VIDEO_PATH=/ruta/al/directorio/de/videos

# --- INTEGRACIÓN CON TMDB (Metadata) ---
TMDB_API_KEY=TU_API_KEY_AQUI
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_IMAGE_BASE_URL=https://image.tmdb.org/t/p/

# --- CONFIGURACIÓN DE CORREO (Nodemailer) ---
# Se recomienda usar "Contraseñas de aplicación" de Google
EMAIL_USER=tu-correo@gmail.com
EMAIL_PASS=tu_password_de_aplicacion_de_16_caracteres